# An .aiignore file follows the same syntax as a .gitignore file.
# .gitignore documentation: https://git-scm.com/docs/gitignore

# you can ignore files
.DS_Store
*.log
*.tmp

# or folders
dist/
build/
out/

# Python
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment files
.env
.env.*
!.env.example

# IDE
.idea/
.vscode/

# Pytest / coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# MyPy / Ruff / caches
.mypy_cache/
.ruff_cache/

# Build artifacts
build/
dist/
*.egg-info/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Local runtime / temp files
tmp/
temp/

# Jupyter
.ipynb_checkpoints/
