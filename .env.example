# =========================
# 当前阶段统一配置文件（唯一来源）
# 说明：代码与 Docker Compose 都直接读取本文件。
# =========================
LLM_DEFAULT_PROVIDER=openai
LLM_TIMEOUT_SECONDS=60

# =========================
# Provider 配置
# 当前阶段允许直接维护开发调试值；本轮不处理 API key 安全治理。
# =========================
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=
OPENAI_DEFAULT_MODEL=gpt-4o-mini

DEEPSEEK_API_KEY=sk-8f20b04bdf1849bb96c78c38948bf8b4
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

GEMINI_API_KEY=your-gemini-api-key
GEMINI_BASE_URL=
GEMINI_DEFAULT_MODEL=gemini-2.0-flash

DOUBAO_API_KEY=45fcac73-1c33-4ba7-b0e1-4bfd96f40271
DOUBAO_BASE_URL=
DOUBAO_DEFAULT_MODEL=doubao-seed-2-0-pro-260215

TONGYI_API_KEY=your-tongyi-api-key
TONGYI_BASE_URL=
TONGYI_DEFAULT_MODEL=

# =========================
# Observability（与 app/config.py 对齐）
# =========================
LOG_ENABLED=true
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_API_PAYLOAD=true
LOG_PROVIDER_PAYLOAD=true

# =========================
# Context Policy（与 app/config.py 对齐）
# =========================
CONTEXT_MAX_TOKEN_BUDGET=1200
CONTEXT_TRUNCATION_TOKEN_BUDGET=900
CONTEXT_SUMMARY_ENABLED=true
CONTEXT_SUMMARY_MAX_CHARS=320
CONTEXT_FALLBACK_BEHAVIOR=summary_then_drop_oldest
CONTEXT_MESSAGE_OVERHEAD_TOKENS=4

# =========================
# Context Store（Phase 3 持久化短期记忆）
# =========================
CONTEXT_STORE_BACKEND=redis
CONTEXT_REDIS_URL=redis://redis:6379/0
CONTEXT_SESSION_TTL_SECONDS=3600
CONTEXT_STORE_KEY_PREFIX=vi_ai_core_service:context
CONTEXT_ALLOW_MEMORY_FALLBACK=false

# =========================
# Context Memory（Phase 4 分层短期记忆）
# =========================
CONTEXT_LAYERED_MEMORY_ENABLED=true
CONTEXT_RECENT_RAW_MAX_TOKEN_BUDGET=900
CONTEXT_RECENT_RAW_MIN_KEEP_MESSAGES=2
CONTEXT_ROLLING_SUMMARY_ENABLED=true
CONTEXT_ROLLING_SUMMARY_MAX_CHARS=1200
CONTEXT_WORKING_MEMORY_ENABLED=true
CONTEXT_WORKING_MEMORY_MAX_ITEMS_PER_SECTION=5
CONTEXT_WORKING_MEMORY_MAX_VALUE_CHARS=160

# =========================
# Streaming（Phase 5 流式会话交付）
# =========================
STREAMING_ENABLED=true
STREAM_HEARTBEAT_INTERVAL_SECONDS=15
STREAM_REQUEST_TIMEOUT_SECONDS=120
STREAM_EMIT_USAGE=true
STREAM_EMIT_TRACE=true
STREAM_CANCEL_ENABLED=true

# =========================
# RAG（Phase 6 Knowledge + Citation Layer）
# =========================
RAG_ENABLED=false
RAG_QDRANT_URL=http://qdrant:6333
RAG_QDRANT_API_KEY=
RAG_QDRANT_COLLECTION=vi_ai_knowledge_chunks
RAG_RETRIEVAL_TOP_K=4
RAG_SCORE_THRESHOLD=
RAG_CHUNK_TOKEN_SIZE=300
RAG_CHUNK_OVERLAP_TOKEN_SIZE=50
RAG_EMBEDDING_PROVIDER=deterministic
RAG_EMBEDDING_MODEL=deterministic-text-v1
RAG_EMBEDDING_DIMENSION=64
RAG_CONTENT_STORE_ROOT=storage

# =========================
# Database（RAG 控制面持久化）
# =========================
DB_URL=mysql+pymysql://root:root@mysql:3306/vi_ai_core_service?charset=utf8mb4
DB_ECHO=false
DB_POOL_PRE_PING=true
