# =========================
# 当前阶段统一配置文件（唯一来源）
# 说明：代码与 Docker Compose 都直接读取本文件。
# =========================
LLM_DEFAULT_PROVIDER=openai
LLM_TIMEOUT_SECONDS=60

# =========================
# Provider 配置
# 当前阶段允许直接维护开发调试值；本轮不处理 API key 安全治理。
# =========================
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=
OPENAI_DEFAULT_MODEL=gpt-4o-mini

DEEPSEEK_API_KEY=sk-8f20b04bdf1849bb96c78c38948bf8b4
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

GEMINI_API_KEY=your-gemini-api-key
GEMINI_BASE_URL=
GEMINI_DEFAULT_MODEL=gemini-2.0-flash

DOUBAO_API_KEY=45fcac73-1c33-4ba7-b0e1-4bfd96f40271
DOUBAO_BASE_URL=
DOUBAO_DEFAULT_MODEL=doubao-seed-2-0-pro-260215

TONGYI_API_KEY=your-tongyi-api-key
TONGYI_BASE_URL=
TONGYI_DEFAULT_MODEL=

# =========================
# Observability（与 app/config.py 对齐）
# =========================
LOG_ENABLED=true
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_API_PAYLOAD=true
LOG_PROVIDER_PAYLOAD=true

# =========================
# Context Policy（与 app/config.py 对齐）
# =========================
CONTEXT_MAX_TOKEN_BUDGET=1200
CONTEXT_TRUNCATION_TOKEN_BUDGET=900
CONTEXT_SUMMARY_ENABLED=true
CONTEXT_SUMMARY_MAX_CHARS=320
CONTEXT_FALLBACK_BEHAVIOR=summary_then_drop_oldest
CONTEXT_MESSAGE_OVERHEAD_TOKENS=4

# =========================
# Context Store（Phase 3 持久化短期记忆）
# =========================
CONTEXT_STORE_BACKEND=redis
CONTEXT_REDIS_URL=redis://redis:6379/0
CONTEXT_SESSION_TTL_SECONDS=86400
CONTEXT_STORE_KEY_PREFIX=vi_ai_core_service:context
CONTEXT_ALLOW_MEMORY_FALLBACK=false
